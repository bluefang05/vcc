# Examples
#   .gitignore for a PHP web project

# Dependencies
vendor/

# Build artifacts
dist/
build/
*.phar

# Logs
*.log
logs/
var/log/

# Environment specific
.env
.env.local
.env.*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db

# Cache directories
.cache/
tmp/
temp/

# Compiled PHP (if using OPcache or similar)
*.opcache

# Session files
*.sess

# Backup files
*~
*.bak
*.backup

# Composer cache (if not in vendor/)
composer.phar
composer.lock

# Testing
.phpunit.result.cache
.phpunit.xml
coverage/
.php_cs.cache

# Legacy admin directory that was removed
vcc-website/admin/